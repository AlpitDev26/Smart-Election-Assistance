spring.datasource.url=jdbc:postgresql://localhost:5432/electiondb
spring.datasource.username=postgres
spring.datasource.password=Alpit@PTSQL2603

# Hibernate will handle the schema automatically
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# Disable external SQL scripts to prevent timing errors
spring.sql.init.mode=never

server.port=8080

logging.level.org.springframework.web=INFO
logging.level.com.election.app=DEBUG
